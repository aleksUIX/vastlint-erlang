%% rebar.config — vastlint Erlang package
%%
%% For pure Erlang projects using rebar3.
%%
%% Fetches the `vastlint` hex package which ships precompiled NIFs for all
%% major platforms. No Rust toolchain required under normal circumstances.
%%
%% To build the NIF from source instead, set the environment variable
%% VASTLINT_BUILD=true and ensure Rust >= 1.86 is installed.

{erl_opts, [debug_info]}.

{deps, [
    %% vastlint hex package — Elixir + Erlang NIF binding for vastlint-core
    {vastlint, "0.3.3"}
]}.

%% Tell rebar3 where Elixir beam files will be (needed for Mix/Elixir deps).
%% If you are building without Elixir, use the rebar3_hex plugin directly
%% and supply the precompiled .so in priv/ as described in the README.
{plugins, [rebar3_hex]}.

{profiles, [
    {test, [
        {erl_opts, [debug_info]},
        {deps, []}
    ]}
]}.
